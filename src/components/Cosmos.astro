---
// Full-viewport WebGL "wormhole nebula" background.
// Self-contained: no library. Falls back to a CSS gradient if WebGL is
// unavailable, and renders a single still frame for reduced-motion users.
---

<canvas id="cosmos" aria-hidden="true"></canvas>
<div class="cosmos-vignette" aria-hidden="true"></div>

<style>
  #cosmos {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    display: block;
    background: radial-gradient(circle at 50% 45%, #10172e, #04050c 75%);
  }
  .cosmos-vignette {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: radial-gradient(circle at 50% 42%, rgba(4, 5, 12, 0) 45%, rgba(4, 5, 12, 0.55) 100%);
  }
</style>

<script>
  const cv = document.getElementById('cosmos') as HTMLCanvasElement | null;
  const gl = cv && (cv.getContext('webgl') || cv.getContext('experimental-webgl')) as WebGLRenderingContext | null;

  if (cv && gl) {
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const vs = 'attribute vec2 p;void main(){gl_Position=vec4(p,0.0,1.0);}';
    const fs = [
      'precision highp float;',
      'uniform float u_time;uniform vec2 u_res;uniform vec2 u_mouse;',
      'float hash(vec2 p){return fract(sin(dot(p,vec2(127.1,311.7)))*43758.5453);}',
      'float noise(vec2 p){vec2 i=floor(p);vec2 f=fract(p);vec2 u=f*f*(3.0-2.0*f);',
      'return mix(mix(hash(i),hash(i+vec2(1.,0.)),u.x),mix(hash(i+vec2(0.,1.)),hash(i+vec2(1.,1.)),u.x),u.y);}',
      'float fbm(vec2 p){float v=0.0,a=0.5;for(int i=0;i<6;i++){v+=a*noise(p);p=p*2.0+vec2(1.7,9.2);a*=0.5;}return v;}',
      'float starLayer(vec2 p,float scale,float thresh){vec2 g=p*scale;vec2 id=floor(g);vec2 f=fract(g)-0.5;',
      'float h=hash(id);vec2 off=(vec2(hash(id+0.17),hash(id+0.39))-0.5)*0.7;float d=length(f-off);',
      'float s=smoothstep(0.05,0.0,d)+smoothstep(0.3,0.0,d)*0.15;float tw=0.55+0.45*sin(u_time*1.4+h*120.0);',
      'return s*tw*step(thresh,h);}',
      'void main(){vec2 uv=(gl_FragCoord.xy-0.5*u_res)/u_res.y;',
      'vec2 puv=uv+(u_mouse-0.5)*0.12;',
      'float tt=u_time*0.02;',
      'vec2 p=puv*1.5+vec2(tt,tt*0.3);',
      'vec2 q=vec2(fbm(p),fbm(p+vec2(5.2,1.3)));',
      'vec2 r=vec2(fbm(p+4.0*q+vec2(1.7,9.2)+tt*0.5),fbm(p+4.0*q+vec2(8.3,2.8)+tt*0.4));',
      'float f=fbm(p+4.0*r);',
      'float hue=fbm(p*0.7+2.0*r+vec2(2.0,-1.0));',
      'vec3 teal=vec3(0.12,0.62,0.70);vec3 cyan=vec3(0.45,0.88,0.96);',
      'vec3 crimson=vec3(0.68,0.13,0.30);vec3 magenta=vec3(0.80,0.28,0.52);vec3 warm=vec3(0.98,0.58,0.34);',
      'vec3 cool=mix(teal,cyan,smoothstep(0.5,0.95,f));',
      'vec3 hot=mix(crimson,magenta,smoothstep(0.4,0.9,f));hot=mix(hot,warm,smoothstep(0.82,1.0,f)*0.5);',
      'vec3 neb=mix(cool,hot,smoothstep(0.38,0.62,hue));',
      'float density=smoothstep(0.50,0.45,f);',
      'vec3 col=mix(vec3(0.012,0.014,0.032),neb,density);',
      'col+=cyan*pow(smoothstep(0.72,1.0,f),3.0)*0.5;',
      'col+=warm*pow(smoothstep(0.8,1.0,f*hue*1.5),3.0)*0.3;',
      'col*=0.55+0.7*f;',
      'float st=starLayer(puv,8.0,0.86)+starLayer(puv,15.0,0.90)*0.8+starLayer(puv,26.0,0.93)*0.6;',
      'col+=vec3(0.9,0.94,1.0)*st*(1.0-density*0.7);',
      'col=pow(max(col,0.0),vec3(0.85));',
      'gl_FragColor=vec4(col,1.0);}'
    ].join('\n');

    const sh = (type: number, src: string) => {
      const o = gl.createShader(type)!;
      gl.shaderSource(o, src);
      gl.compileShader(o);
      return o;
    };
    const prog = gl.createProgram()!;
    gl.attachShader(prog, sh(gl.VERTEX_SHADER, vs));
    gl.attachShader(prog, sh(gl.FRAGMENT_SHADER, fs));
    gl.linkProgram(prog);
    gl.useProgram(prog);

    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(gl.ARRAY_BUFFER, new Float32Array([-1, -1, 3, -1, -1, 3]), gl.STATIC_DRAW);
    const loc = gl.getAttribLocation(prog, 'p');
    gl.enableVertexAttribArray(loc);
    gl.vertexAttribPointer(loc, 2, gl.FLOAT, false, 0, 0);

    const uT = gl.getUniformLocation(prog, 'u_time');
    const uR = gl.getUniformLocation(prog, 'u_res');
    const uM = gl.getUniformLocation(prog, 'u_mouse');

    const mouse = [0.5, 0.5];
    const target = [0.5, 0.5];
    window.addEventListener('mousemove', (e) => {
      target[0] = e.clientX / window.innerWidth;
      target[1] = 1.0 - e.clientY / window.innerHeight;
    });

    const resize = () => {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      cv.width = Math.floor(window.innerWidth * dpr);
      cv.height = Math.floor(window.innerHeight * dpr);
      gl.viewport(0, 0, cv.width, cv.height);
    };
    resize();
    window.addEventListener('resize', resize);

    const draw = (time: number) => {
      mouse[0] += (target[0] - mouse[0]) * 0.05;
      mouse[1] += (target[1] - mouse[1]) * 0.05;
      gl.uniform1f(uT, time);
      gl.uniform2f(uR, cv.width, cv.height);
      gl.uniform2f(uM, mouse[0], mouse[1]);
      gl.drawArrays(gl.TRIANGLES, 0, 3);
    };

    if (reduce) {
      draw(8.0);
    } else {
      const t0 = performance.now();
      const loop = () => {
        draw((performance.now() - t0) / 1000);
        requestAnimationFrame(loop);
      };
      loop();
    }
  }
</script>
