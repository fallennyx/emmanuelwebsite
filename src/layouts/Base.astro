---
import '../styles/global.css';
import Cosmos from '../components/Cosmos.astro';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
  description?: string;
  dim?: boolean | 'strong';
}

const {
  title = 'Emmanuel Akanmu',
  description = 'Writer, builder, and collector of artifacts — assembling everything I make, out in the open.',
  dim = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Space+Grotesk:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Cosmos />
    {dim && <div class:list={['page-dim', dim === 'strong' && 'page-dim--strong']} aria-hidden="true"></div>}
    <Nav />
    <main>
      <slot />
    </main>
    <footer>
      <div class="wrap">
        <span>© {new Date().getFullYear()} Emmanuel Akanmu</span>
        <a class="dim" href="https://github.com/fallennyx">github</a>
      </div>
    </footer>

    <style>
      main { position: relative; z-index: 1; }
      .page-dim {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background: radial-gradient(circle at 50% 42%, rgba(6, 5, 15, 0.72), rgba(6, 5, 15, 0.58) 100%);
      }
      /* Reading view: near-opaque veil so long-form text stays legible;
         the nebula still shows faintly underneath. */
      .page-dim--strong {
        background: radial-gradient(circle at 50% 42%, rgba(3, 4, 10, 0.9), rgba(2, 3, 8, 0.95) 100%);
      }
      footer {
        position: relative;
        z-index: 1;
        margin-top: 6rem;
        padding: 2rem 0 3rem;
        border-top: 1px solid var(--border);
      }
      footer .wrap {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        letter-spacing: 1px;
        color: var(--faint);
      }
      footer .dim { font-style: italic; }
      @media (max-width: 520px) {
        footer .wrap { flex-direction: column; gap: 6px; }
      }
    </style>
  </body>
</html>
