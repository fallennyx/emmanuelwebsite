---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryCard from '../../components/EntryCard.astro';

const entries = (await getCollection('archive', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const filters = [
  { key: 'all', label: 'All' },
  { key: 'writing', label: 'Writing' },
  { key: 'project', label: 'Projects' },
  { key: 'research', label: 'Research' },
];
---

<Base title="Archive — Emmanuel Akanmu" dim={true}>
  <section class="wrap page">
    <p class="eyebrow">archive</p>
    <h1>Everything I make</h1>
    <p class="lede">Writing, projects, and research — collected in one place. Filter to narrow it down.</p>

    <div class="filter">
      {filters.map((f) => (
        <button class:list={['chip', { active: f.key === 'all' }]} data-filter={f.key}>
          {f.label}
        </button>
      ))}
    </div>

    {entries.length === 0 ? (
      <p class="empty">Nothing archived yet.</p>
    ) : (
      <div class="grid" id="grid">
        {entries.map((e) => (
          <EntryCard {...e.data} slug={e.id} />
        ))}
      </div>
    )}
    <p class="empty" id="empty" hidden>Nothing in this category yet.</p>
  </section>
</Base>

<script>
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.chip'));
  const cards = Array.from(document.querySelectorAll<HTMLElement>('#grid [data-category]'));
  const empty = document.getElementById('empty');

  chips.forEach((chip) => {
    chip.addEventListener('click', () => {
      const f = chip.dataset.filter;
      chips.forEach((c) => c.classList.toggle('active', c === chip));
      let shown = 0;
      cards.forEach((card) => {
        const match = f === 'all' || card.dataset.category === f;
        card.hidden = !match;
        if (match) shown += 1;
      });
      if (empty) empty.hidden = shown > 0;
    });
  });
</script>

<style>
  .page { padding-top: 3rem; max-width: 980px; }
  .page h1 { font-size: clamp(34px, 7vw, 52px); color: #fff; margin: 14px 0 0.8rem; }
  .lede { color: var(--muted); max-width: 520px; margin-bottom: 2rem; }

  .filter {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 2.5rem;
  }
  .chip {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.5px;
    color: var(--muted);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 7px 18px;
    cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .chip:hover { color: #fff; border-color: var(--border-strong); }
  .chip.active {
    color: #fff;
    border-color: var(--accent);
    background: rgba(111, 180, 255, 0.12);
  }

  .empty { color: var(--muted); }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
  }
</style>
